---
import '../styles/guide.css';

interface Props {
  lang: 'en' | 'fi' | 'sv' | 'ar';
  title: string;
}

const { lang, title } = Astro.props;

const alternates = [
  { lang: 'en', href: '/' },
  { lang: 'fi', href: '/fi/' },
  { lang: 'sv', href: '/sv/' },
  { lang: 'ar', href: '/ar/' },
] as const;

const dir = lang === 'ar' ? 'rtl' : 'ltr';

const copyLabels = {
  en: { copy: 'Copy', copied: 'Copied!', failed: 'Failed', ariaCopy: 'Copy prompt to clipboard', ariaCopied: 'Copied to clipboard' },
  fi: { copy: 'Kopioi', copied: 'Kopioitu!', failed: 'Epäonnistui', ariaCopy: 'Kopioi kehote leikepöydälle', ariaCopied: 'Kopioitu leikepöydälle' },
  sv: { copy: 'Kopiera', copied: 'Kopierat!', failed: 'Misslyckades', ariaCopy: 'Kopiera prompt till urklipp', ariaCopied: 'Kopierat till urklipp' },
  ar: { copy: 'نسخ', copied: 'تم النسخ!', failed: 'فشل', ariaCopy: 'نسخ الموجّه إلى الحافظة', ariaCopied: 'تم النسخ إلى الحافظة' },
} as const;

const labels = copyLabels[lang];
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {alternates.map(({ lang: hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        document.querySelectorAll('pre.prompt').forEach(function (pre) {
          var block = document.createElement('div');
          block.className = 'prompt-block';
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'copy-btn';
          btn.textContent = {JSON.stringify(labels.copy)};
          btn.setAttribute('aria-label', {JSON.stringify(labels.ariaCopy)});
          pre.parentNode.insertBefore(block, pre);
          block.append(btn, pre);
        });

        document.body.addEventListener('click', function (e) {
          var btn = e.target.closest('.copy-btn');
          if (!btn) return;

          var pre = btn.parentElement.querySelector('pre.prompt');
          if (!pre) return;

          var text = pre.textContent.trim();

          function showCopied() {
            btn.textContent = {JSON.stringify(labels.copied)};
            btn.classList.add('copied');
            btn.setAttribute('aria-label', {JSON.stringify(labels.ariaCopied)});
            window.setTimeout(function () {
              btn.textContent = {JSON.stringify(labels.copy)};
              btn.classList.remove('copied');
              btn.setAttribute('aria-label', {JSON.stringify(labels.ariaCopy)});
            }, 2000);
          }

          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(showCopied).catch(fallbackCopy);
          } else {
            fallbackCopy();
          }

          function fallbackCopy() {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.setAttribute('readonly', '');
            ta.style.position = 'fixed';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            try {
              document.execCommand('copy');
              showCopied();
            } catch (err) {
              btn.textContent = {JSON.stringify(labels.failed)};
              window.setTimeout(function () {
                btn.textContent = {JSON.stringify(labels.copy)};
              }, 2000);
            }
            document.body.removeChild(ta);
          }
        });
      })();
    </script>
  </body>
</html>

---
import GuideLayout from "../../layouts/GuideLayout.astro";
import content from "../../content/fi.html?raw";

const lang = "fi";
const title =
  "Ideasta verkkosivuksi: Tekoälyavusteinen koodaus aloittelijoille";
const description =
  "Asenna OpenCode, GitHub ja Vercel ennen kuin aloitamme rakentamisen. Lisää tämä sivu kirjanmerkkeihin, jotta löydät sen helposti.";
---

<GuideLayout lang={lang} title={title} description={description}>
  <Fragment set:html={content} />
</GuideLayout>
